# Local dev — SQLite (no setup needed)
DATABASE_URL=sqlite:///./scout.db

# Production — swap for Supabase connection string
# DATABASE_URL=postgresql://user:password@host:5432/dbname

GROQ_API_KEY=your_groq_key_here

# CORS — set to your frontend origin (e.g. http://localhost:3000 for local dev)
ALLOWED_ORIGIN=http://localhost:3000

# Auth — set a secret key; leave unset to disable auth in local dev
# SCOUT_API_KEY=your_secret_here

# Club configuration — set to any Big 5 club
CLUB_NAME=Paris Saint-Germain
CLUB_LEAGUE=Ligue 1
